---
import { categories, getToolsByCategory, toolRegistry } from '../config/tools'
import { t, getCategoryName, getOtherLanguages, languageNames } from '../i18n'
import type { Language, MessageKey } from '../i18n'
import BrandMark from './BrandMark.astro'
import { appVersion, upstreamRepositoryUrl } from '../config/site'

interface Props {
  lang: Language
}

const { lang } = Astro.props
const otherLangs = getOtherLanguages(lang)
const totalTools = categories.reduce((total, category) => total + getToolsByCategory(category).length, 0)

// Build lookup maps for client-side favorites rendering
const homeToolData: Record<string, { name: string; desc: string; icon: string; category: string }> = {}
for (const tool of toolRegistry) {
  const nameKey = `tools_${tool.id.replace(/-([a-z])/g, (_, c: string) => c.toUpperCase())}_name` as MessageKey
  const descKey = `tools_${tool.id.replace(/-([a-z])/g, (_, c: string) => c.toUpperCase())}_description` as MessageKey
  homeToolData[tool.id] = {
    name: t(lang, nameKey),
    desc: t(lang, descKey),
    icon: tool.icon,
    category: tool.category,
  }
}

const categoryColors: Record<string, string> = {
  'text-processing': 'from-teal-500/10 to-cyan-500/10 border-teal-500/20 hover:border-teal-400',
  'generators': 'from-violet-500/10 to-purple-500/10 border-violet-500/20 hover:border-violet-400',
  'extraction': 'from-blue-500/10 to-indigo-500/10 border-blue-500/20 hover:border-blue-400',
  'analysis': 'from-amber-500/10 to-orange-500/10 border-amber-500/20 hover:border-amber-400',
  'security': 'from-rose-500/10 to-pink-500/10 border-rose-500/20 hover:border-rose-400',
  'converters': 'from-emerald-500/10 to-green-500/10 border-emerald-500/20 hover:border-emerald-400',
  'development': 'from-sky-500/10 to-blue-500/10 border-sky-500/20 hover:border-sky-400',
  'utilities': 'from-fuchsia-500/10 to-pink-500/10 border-fuchsia-500/20 hover:border-fuchsia-400',
}

const categoryAccents: Record<string, string> = {
  'text-processing': 'text-teal-600 dark:text-teal-400',
  'generators': 'text-violet-600 dark:text-violet-400',
  'extraction': 'text-blue-600 dark:text-blue-400',
  'analysis': 'text-amber-600 dark:text-amber-400',
  'security': 'text-rose-600 dark:text-rose-400',
  'converters': 'text-emerald-600 dark:text-emerald-400',
  'development': 'text-sky-600 dark:text-sky-400',
  'utilities': 'text-fuchsia-600 dark:text-fuchsia-400',
}
---

<div class="min-h-screen">
  <!-- Sticky top bar -->
  <header class="sticky top-0 z-30 flex items-center justify-between border-b border-border/50 bg-surface/80 px-4 py-2.5 backdrop-blur-lg sm:px-6">
    <span class="flex items-center gap-2 text-sm font-semibold text-text-primary">
      <BrandMark
        wrapperClass="inline-flex h-8 w-8 items-center justify-center overflow-hidden rounded-lg bg-gradient-to-br from-teal-500 to-indigo-500 text-white shadow-sm shadow-teal-500/20"
        imageClass="h-full w-full object-contain bg-surface-raised"
        fallbackClass="inline-flex h-full w-full items-center justify-center p-1.5"
      />
      <span>{t(lang, 'app_title')}</span>
    </span>
    <div class="flex items-center gap-2">
      <span class="hidden h-9 items-center rounded-lg border border-accent/30 bg-accent/10 px-3 text-sm font-semibold tracking-wide text-accent sm:inline-flex">
        v{appVersion}
      </span>
      <button
        type="button"
        id="home-search-trigger"
        class="inline-flex h-9 items-center gap-2 rounded-lg border border-border bg-surface-raised px-3 text-sm text-text-muted transition-colors hover:border-accent hover:text-text-secondary cursor-pointer"
      >
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <span class="hidden sm:inline">{t(lang, 'app_searchPlaceholder')}</span>
        <kbd class="hidden sm:inline-flex items-center gap-0.5 rounded border border-border px-1.5 py-0.5 text-[10px] font-medium text-text-muted">
          <span>⌘</span>K
        </kbd>
      </button>
      <!-- Theme toggle -->
      <button
        type="button"
        id="theme-toggle"
        class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-border bg-surface-raised text-text-secondary transition-colors hover:bg-surface-raised hover:text-accent cursor-pointer"
        aria-label={t(lang, 'app_themeToggleAria')}
        title={t(lang, 'app_themeToggleAria')}
      >
        <!-- Sun icon (shown in dark mode) -->
        <svg id="theme-icon-light" class="h-4 w-4 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
        <!-- Moon icon (shown in light mode) -->
        <svg id="theme-icon-dark" class="h-4 w-4 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
        <!-- Monitor icon (shown in system mode) -->
        <svg id="theme-icon-system" class="h-4 w-4 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
      </button>
      <div class="relative" data-lang-dropdown>
        <button
          type="button"
          class="inline-flex h-9 min-w-9 items-center justify-center gap-1 rounded-lg border border-border bg-surface-raised px-3 text-sm font-medium text-text-secondary hover:text-accent transition-colors cursor-pointer"
          title={t(lang, 'app_switchLanguageAria')}
          aria-haspopup="true"
          aria-expanded="false"
        >
          {lang.toUpperCase()}
          <svg class="h-3 w-3 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="absolute right-0 top-full z-50 mt-1 hidden min-w-[8rem] overflow-hidden rounded-lg border border-border bg-surface shadow-lg" data-lang-menu>
          {otherLangs.map((l) => (
            <a
              href={`/${l}/`}
              class="flex items-center gap-2 px-3 py-2 text-sm text-text-secondary hover:bg-surface-raised hover:text-accent transition-colors"
            >
              <span class="w-6 font-medium">{l.toUpperCase()}</span>
              <span class="text-text-muted">{languageNames[l]}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </header>

  <!-- Hero -->
  <div class="relative overflow-hidden">
    <!-- Gradient background blobs -->
    <div class="pointer-events-none absolute -top-40 left-1/2 -translate-x-1/2">
      <div class="h-80 w-[40rem] rounded-full bg-gradient-to-r from-teal-400/20 via-indigo-400/20 to-pink-400/20 blur-3xl"></div>
    </div>

    <div class="relative mx-auto max-w-4xl px-4 pb-12 pt-16 text-center sm:pt-20">
      <!-- Logo mark -->
      <BrandMark
        wrapperClass="mx-auto mb-6 flex h-16 w-16 items-center justify-center overflow-hidden rounded-2xl bg-gradient-to-br from-teal-500 to-indigo-500 text-white shadow-lg shadow-teal-500/25"
        imageClass="h-full w-full object-contain bg-surface-raised"
        fallbackClass="inline-flex h-full w-full items-center justify-center p-4"
      />

      <h1 class="mb-3 text-4xl font-extrabold tracking-tight text-text-primary sm:text-5xl">
        {t(lang, 'home_title')}
      </h1>
      <p class="mx-auto mb-8 max-w-xl text-lg text-text-secondary">
        {t(lang, 'home_description')}
      </p>

      <!-- Stats pills -->
      <div class="flex flex-wrap items-center justify-center gap-3">
        <span class="inline-flex items-center gap-1.5 rounded-full bg-accent/10 px-3 py-1 text-sm font-medium text-accent">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
          {totalTools} tools
        </span>
        <span class="inline-flex items-center gap-1.5 rounded-full bg-surface-raised px-3 py-1 text-sm text-text-secondary">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          EN / IT / ES / FR / DE
        </span>
        <span class="inline-flex items-center gap-1.5 rounded-full bg-surface-raised px-3 py-1 text-sm text-text-secondary">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          100% client-side
        </span>
      </div>
    </div>
  </div>

  <!-- Tool catalog -->
  <div class="mx-auto max-w-6xl px-4 pb-20">
    <!-- Favorites section (populated client-side) -->
    <section id="home-favorites" class="mb-12 hidden" data-lang={lang}>
      <div class="mb-5 flex items-center gap-3">
        <h2 class="text-sm font-bold uppercase tracking-widest text-amber-500 dark:text-amber-400">
          ⭐ {t(lang, 'favorites_title')}
        </h2>
        <div class="h-px flex-1 bg-border"></div>
        <span id="home-favorites-count" class="text-xs text-text-muted">0</span>
      </div>
      <div id="home-favorites-grid" class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3"></div>
    </section>

    {categories.map((cat) => {
      const tools = getToolsByCategory(cat)
      const colorClass = categoryColors[cat] ?? ''
      const accentClass = categoryAccents[cat] ?? 'text-accent'
      return (
        <section class="mb-12">
          <div class="mb-5 flex items-center gap-3">
            <h2 class={`text-sm font-bold uppercase tracking-widest ${accentClass}`}>
              {getCategoryName(lang, cat)}
            </h2>
            <div class="h-px flex-1 bg-border"></div>
            <span class="text-xs text-text-muted">{tools.length}</span>
          </div>
          <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
            {tools.map((tool) => {
              const nameKey = `tools_${tool.id.replace(/-([a-z])/g, (_, c: string) => c.toUpperCase())}_name` as MessageKey
              const descKey = `tools_${tool.id.replace(/-([a-z])/g, (_, c: string) => c.toUpperCase())}_description` as MessageKey
              return (
                <a
                  href={`/${lang}/tools/${tool.id}/`}
                  class={`group relative flex items-start gap-3.5 rounded-xl border bg-gradient-to-br p-4 transition-all duration-200 hover:shadow-lg hover:-translate-y-0.5 ${colorClass}`}
                >
                  <span class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-surface/80 text-xl shadow-sm" role="img" aria-hidden="true">
                    {tool.icon}
                  </span>
                  <div class="min-w-0">
                    <h3 class="font-semibold text-text-primary group-hover:text-accent transition-colors">
                      {t(lang, nameKey)}
                    </h3>
                    <p class="mt-0.5 text-sm leading-relaxed text-text-secondary line-clamp-2">{t(lang, descKey)}</p>
                  </div>
                  <svg class="absolute right-3 top-4 h-4 w-4 text-text-muted opacity-0 transition-all group-hover:opacity-100 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
                </a>
              )
            })}
          </div>
        </section>
      )
    })}
  </div>

  <!-- Footer -->
  <footer class="border-t border-border px-4 py-6 text-center text-sm text-text-muted">
    {t(lang, 'home_footerName')} &middot;
    <a href={upstreamRepositoryUrl} class="text-text-secondary hover:text-accent transition-colors">
      {t(lang, 'home_footerGithub')}
    </a>
    &middot; <span class="text-text-muted">v{appVersion}</span>
  </footer>
</div>

<!-- Trigger command palette from search button + theme toggle -->
<script>
  function initHomeSearch() {
    const btn = document.getElementById('home-search-trigger')
    if (btn) {
      btn.addEventListener('click', () => {
        document.dispatchEvent(new KeyboardEvent('keydown', { key: 'k', metaKey: true }))
      })
    }
  }

  function initThemeToggle() {
    const btn = document.getElementById('theme-toggle')
    if (!btn) return

    function getStoredPreference(): string {
      return localStorage.getItem('theme') || 'system'
    }

    function updateIcon(pref: string) {
      const iconLight = document.getElementById('theme-icon-light')
      const iconDark = document.getElementById('theme-icon-dark')
      const iconSystem = document.getElementById('theme-icon-system')
      if (!iconLight || !iconDark || !iconSystem) return
      iconLight.classList.add('hidden')
      iconDark.classList.add('hidden')
      iconSystem.classList.add('hidden')
      if (pref === 'light') iconDark.classList.remove('hidden')
      else if (pref === 'dark') iconLight.classList.remove('hidden')
      else iconSystem.classList.remove('hidden')
    }

    function applyTheme(pref: string) {
      let effective = pref
      if (pref === 'system') {
        effective = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light'
      }
      document.documentElement.setAttribute('data-theme', effective)
    }

    function cyclePref(current: string): string {
      if (current === 'system') return 'light'
      if (current === 'light') return 'dark'
      return 'system'
    }

    let pref = getStoredPreference()
    applyTheme(pref)
    updateIcon(pref)

    btn.addEventListener('click', () => {
      pref = cyclePref(pref)
      if (pref === 'system') {
        localStorage.removeItem('theme')
      } else {
        localStorage.setItem('theme', pref)
      }
      applyTheme(pref)
      updateIcon(pref)
    })

    // Listen for system theme changes when in "system" mode
    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
      if (getStoredPreference() === 'system') {
        applyTheme('system')
      }
    })
  }

  initHomeSearch()
  initThemeToggle()
  document.addEventListener('astro:page-load', () => {
    initHomeSearch()
    initThemeToggle()
  })
</script>

<!-- Home favorites hydration -->
<script define:vars={{ homeToolData, categoryColors: categoryColors }} is:inline>
  function initHomeFavorites() {
    var section = document.getElementById('home-favorites')
    if (!section) return
    var lang = section.dataset.lang
    var grid = document.getElementById('home-favorites-grid')
    var countEl = document.getElementById('home-favorites-count')
    if (!grid) return

    var raw = localStorage.getItem('favorite-tools')
    if (!raw) { section.classList.add('hidden'); return }

    try {
      var favIds = JSON.parse(raw)
      if (!Array.isArray(favIds) || favIds.length === 0) { section.classList.add('hidden'); return }

      grid.innerHTML = ''
      var count = 0

      for (var i = 0; i < favIds.length; i++) {
        var id = favIds[i]
        var data = homeToolData[id]
        if (!data) continue
        count++

        var colorClass = categoryColors[data.category] || ''
        var href = '/' + lang + '/tools/' + id + '/'

        var a = document.createElement('a')
        a.href = href
        a.className = 'group relative flex items-start gap-3.5 rounded-xl border bg-gradient-to-br p-4 transition-all duration-200 hover:shadow-lg hover:-translate-y-0.5 ' + colorClass

        a.innerHTML = '<span class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-surface/80 text-xl shadow-sm" role="img" aria-hidden="true">' + data.icon + '</span>'
          + '<div class="min-w-0"><h3 class="font-semibold text-text-primary group-hover:text-accent transition-colors">' + data.name + '</h3>'
          + '<p class="mt-0.5 text-sm leading-relaxed text-text-secondary line-clamp-2">' + data.desc + '</p></div>'
          + '<svg class="absolute right-3 top-4 h-4 w-4 text-text-muted opacity-0 transition-all group-hover:opacity-100 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>'

        grid.appendChild(a)
      }

      if (countEl) countEl.textContent = String(count)
      if (count > 0) {
        section.classList.remove('hidden')
      } else {
        section.classList.add('hidden')
      }
    } catch (e) {
      section.classList.add('hidden')
    }
  }

  initHomeFavorites()
  document.addEventListener('astro:page-load', initHomeFavorites)
</script>
