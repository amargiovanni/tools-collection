---
import { ClientRouter } from 'astro:transitions'
import '../styles/global.css'
import { languages, getOtherLanguages } from '../i18n'
import type { Language } from '../i18n'

const supportedLangs = [...languages]
import CommandPalette from '../islands/CommandPalette'
import { customLogoPath } from '../config/site'

interface Props {
  title: string
  description?: string
  lang: Language
}

const { title, description, lang } = Astro.props
const currentPath = Astro.url.pathname
const siteBase = Astro.site ?? 'https://tools.example.com'
const canonicalUrl = new URL(currentPath, siteBase).href
const altLinks = getOtherLanguages(lang).map((l) => ({
  lang: l,
  href: new URL(currentPath.replace(`/${lang}/`, `/${l}/`), siteBase).href,
}))
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang={lang} href={canonicalUrl} />
    {altLinks.map(({ lang: l, href }) => (
      <link rel="alternate" hreflang={l} href={href} />
    ))}
    <script is:inline src="/default-language.js"></script>
    <ClientRouter />
    <!-- Theme: apply before paint to avoid flash -->
    <script is:inline>
      ;(function () {
        var stored = localStorage.getItem('theme')
        var theme = stored === 'light' || stored === 'dark' ? stored : null
        if (!theme) {
          theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light'
        }
        document.documentElement.setAttribute('data-theme', theme)
      })()
    </script>
    <!-- Legacy hash redirect: #json-formatter → /en/tools/json-formatter -->
    <script define:vars={{ supportedLangs }} is:inline>
      ;(function () {
        var hash = location.hash.slice(1)
        if (!hash) return
        var renames = {
          'cert-extractor': 'pem-inspector',
          'password-checker': 'password-strength',
          'qr-generator': 'qr-code',
          'emoji-converter': 'emoji-shortcode',
          'base64-converter': 'base64',
          'add-text-lines': 'add-text-to-lines',
          'remove-duplicates': 'remove-duplicate-lines',
        }
        var slug = renames[hash] || hash
        var stored = localStorage.getItem('lang')
        var configuredDefault =
          typeof window.__DEFAULT_LANGUAGE__ === 'string' &&
          supportedLangs.indexOf(window.__DEFAULT_LANGUAGE__) !== -1
            ? window.__DEFAULT_LANGUAGE__
            : 'en'
        var lang =
          stored && supportedLangs.indexOf(stored) !== -1
            ? stored
            : configuredDefault
        location.replace('/' + lang + '/tools/' + slug + '/')
      })()
    </script>
  </head>
  <body class="bg-surface text-text-primary min-h-screen">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:rounded-lg focus:bg-accent focus:px-4 focus:py-2 focus:text-white"
    >
      Skip to content
    </a>
    <slot />
    <CommandPalette client:only="solid-js" lang={lang} />
    <script define:vars={{ customLogoPath }} is:inline>
      function initCustomLogos() {
        document.querySelectorAll('[data-brand-container]').forEach(function (container) {
          if (container.dataset.logoResolved === 'true') return
          container.dataset.logoResolved = 'true'

          var image = container.querySelector('[data-brand-logo]')
          var fallback = container.querySelector('[data-brand-fallback]')
          if (!image || !fallback) return

          image.addEventListener('load', function () {
            container.dataset.brandMode = 'custom'
            fallback.hidden = true
            image.hidden = false
          })

          image.addEventListener('error', function () {
            container.dataset.brandMode = 'fallback'
            image.hidden = true
            fallback.hidden = false
          })

          image.setAttribute('src', customLogoPath)

          if (image.complete) {
            if (image.naturalWidth > 0) {
              container.dataset.brandMode = 'custom'
              fallback.hidden = true
              image.hidden = false
            } else {
              container.dataset.brandMode = 'fallback'
              image.hidden = true
              fallback.hidden = false
            }
          }
        })
      }

      initCustomLogos()
      document.addEventListener('astro:page-load', initCustomLogos)
    </script>
    <!-- Language dropdown toggle -->
    <script is:inline>
      function initLangDropdowns() {
        document.querySelectorAll('[data-lang-dropdown]').forEach(function (dropdown) {
          var btn = dropdown.querySelector('button')
          var menu = dropdown.querySelector('[data-lang-menu]')
          if (!btn || !menu || btn.dataset.langBound === 'true') return
          btn.dataset.langBound = 'true'

          btn.addEventListener('click', function (e) {
            e.stopPropagation()
            var isOpen = !menu.classList.contains('hidden')
            closeAllLangMenus()
            if (!isOpen) {
              menu.classList.remove('hidden')
              btn.setAttribute('aria-expanded', 'true')
            }
          })
        })
      }

      function closeAllLangMenus() {
        document.querySelectorAll('[data-lang-dropdown]').forEach(function (d) {
          var m = d.querySelector('[data-lang-menu]')
          var b = d.querySelector('button')
          if (m) m.classList.add('hidden')
          if (b) b.setAttribute('aria-expanded', 'false')
        })
      }

      document.addEventListener('click', closeAllLangMenus)
      initLangDropdowns()
      document.addEventListener('astro:page-load', initLangDropdowns)
    </script>
  </body>
</html>
