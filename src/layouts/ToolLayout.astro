---
import BaseLayout from './BaseLayout.astro'
import Sidebar from '../components/Sidebar.astro'
import BrandMark from '../components/BrandMark.astro'
import { t, getOtherLanguages, languageNames } from '../i18n'
import type { Language, MessageKey } from '../i18n'
import type { ToolMeta } from '../config/tools'
import { appVersion, upstreamRepositoryUrl } from '../config/site'

interface Props {
  tool: ToolMeta
  lang: Language
}

const { tool, lang } = Astro.props
const otherLangs = getOtherLanguages(lang)
const nameKey = `tools_${tool.id.replace(/-([a-z])/g, (_, c: string) => c.toUpperCase())}_name` as MessageKey
const descKey = `tools_${tool.id.replace(/-([a-z])/g, (_, c: string) => c.toUpperCase())}_description` as MessageKey
const toolName = t(lang, nameKey)
const toolDesc = t(lang, descKey)
const currentPath = Astro.url.pathname
---

<BaseLayout title={`${toolName} — ${t(lang, 'app_documentTitle')}`} description={toolDesc} lang={lang}>
  <div class="flex min-h-screen">
    <!-- Sidebar (desktop) -->
    <aside class="hidden lg:flex w-72 shrink-0 flex-col border-r border-border bg-surface overflow-y-auto h-screen sticky top-0">
      <div class="flex items-center gap-2 border-b border-border px-4 py-3">
        <a href={`/${lang}/`} class="flex items-center gap-2 text-sm font-semibold text-text-primary hover:text-accent transition-colors" title={t(lang, 'app_backHomeAria')}>
          <BrandMark
            wrapperClass="inline-flex h-8 w-8 items-center justify-center overflow-hidden rounded-lg bg-gradient-to-br from-teal-500 to-indigo-500 text-white shadow-sm shadow-teal-500/20"
            imageClass="h-full w-full object-contain bg-surface-raised"
            fallbackClass="inline-flex h-full w-full items-center justify-center p-1.5"
          />
          <span>{t(lang, 'app_title')}</span>
        </a>
      </div>
      <Sidebar lang={lang} currentPath={currentPath} />
    </aside>

    <!-- Main content -->
    <div class="flex flex-1 flex-col">
      <!-- Top bar -->
      <header class="flex items-center gap-3 border-b border-border px-4 py-3 lg:px-6">
        <!-- Mobile menu button -->
        <button
          type="button"
          id="mobile-menu-toggle"
          class="lg:hidden text-text-secondary hover:text-text-primary cursor-pointer"
          aria-label={t(lang, 'app_mobileMenuAria')}
        >
          <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>

        <div class="flex items-center gap-2">
          <span class="text-xl" aria-hidden="true">{tool.icon}</span>
          <h1 class="text-lg font-semibold text-text-primary" tabindex="-1" id="tool-heading">
            {toolName}
          </h1>
          <button
            type="button"
            id="favorite-toggle"
            data-tool-id={tool.id}
            data-add-label={t(lang, 'favorites_add')}
            data-remove-label={t(lang, 'favorites_remove')}
            class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-text-muted transition-colors hover:text-amber-500 cursor-pointer"
            aria-label={t(lang, 'favorites_add')}
          >
            <!-- Empty star (not favorite) -->
            <svg id="fav-icon-empty" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
            </svg>
            <!-- Filled star (favorite) -->
            <svg id="fav-icon-filled" class="h-5 w-5 hidden text-amber-500" fill="currentColor" viewBox="0 0 24 24">
              <path d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
            </svg>
          </button>
        </div>

        <div class="ml-auto flex items-center gap-2">
          <span class="hidden h-9 items-center rounded-lg border border-accent/30 bg-accent/10 px-3 text-sm font-semibold tracking-wide text-accent sm:inline-flex">
            v{appVersion}
          </span>
          <button
            type="button"
            id="tool-search-trigger"
            class="inline-flex h-9 items-center gap-2 rounded-lg border border-border bg-surface-raised px-3 text-sm text-text-muted transition-colors hover:border-accent hover:text-text-secondary cursor-pointer"
          >
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <span class="hidden sm:inline">{t(lang, 'app_searchPlaceholder')}</span>
            <kbd class="hidden sm:inline-flex items-center gap-0.5 rounded border border-border px-1.5 py-0.5 text-[10px] font-medium text-text-muted">
              <span>⌘</span>K
            </kbd>
          </button>
          <!-- Theme toggle -->
          <button
            type="button"
            id="theme-toggle"
            class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-border bg-surface-raised text-text-secondary transition-colors hover:bg-surface-raised hover:text-accent cursor-pointer"
            aria-label={t(lang, 'app_themeToggleAria')}
            title={t(lang, 'app_themeToggleAria')}
          >
            <svg id="theme-icon-light" class="h-4 w-4 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
            <svg id="theme-icon-dark" class="h-4 w-4 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
            </svg>
            <svg id="theme-icon-system" class="h-4 w-4 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </button>
          <!-- Language switcher dropdown -->
          <div class="relative" data-lang-dropdown>
            <button
              type="button"
              class="inline-flex h-9 min-w-9 items-center justify-center gap-1 rounded-lg border border-border bg-surface-raised px-3 text-sm font-medium text-text-secondary hover:text-accent transition-colors cursor-pointer"
              title={t(lang, 'app_switchLanguageAria')}
              aria-haspopup="true"
              aria-expanded="false"
            >
              {lang.toUpperCase()}
              <svg class="h-3 w-3 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class="absolute right-0 top-full z-50 mt-1 hidden min-w-[8rem] overflow-hidden rounded-lg border border-border bg-surface shadow-lg" data-lang-menu>
              {otherLangs.map((l) => (
                <a
                  href={`/${l}/tools/${tool.id}/`}
                  class="flex items-center gap-2 px-3 py-2 text-sm text-text-secondary hover:bg-surface-raised hover:text-accent transition-colors"
                >
                  <span class="w-6 font-medium">{l.toUpperCase()}</span>
                  <span class="text-text-muted">{languageNames[l]}</span>
                </a>
              ))}
            </div>
          </div>
        </div>
      </header>

      <!-- Mobile sidebar overlay -->
      <div id="mobile-sidebar-overlay" class="fixed inset-0 z-40 hidden lg:hidden">
        <div class="absolute inset-0 bg-black/50" id="mobile-overlay-backdrop"></div>
        <aside class="absolute left-0 top-0 h-full w-72 overflow-y-auto bg-surface border-r border-border">
          <div class="flex items-center justify-between border-b border-border px-4 py-3">
            <a href={`/${lang}/`} class="flex items-center gap-2 text-sm font-semibold text-text-primary">
              <BrandMark
                wrapperClass="inline-flex h-8 w-8 items-center justify-center overflow-hidden rounded-lg bg-gradient-to-br from-teal-500 to-indigo-500 text-white shadow-sm shadow-teal-500/20"
                imageClass="h-full w-full object-contain bg-surface-raised"
                fallbackClass="inline-flex h-full w-full items-center justify-center p-1.5"
              />
              <span>{t(lang, 'app_title')}</span>
            </a>
            <button type="button" id="mobile-menu-close" class="text-text-secondary hover:text-text-primary cursor-pointer" aria-label="Close menu">
              ✕
            </button>
          </div>
          <Sidebar lang={lang} currentPath={currentPath} />
        </aside>
      </div>

      <!-- Tool content -->
      <main id="main-content" class="flex-1 px-4 py-6 lg:px-8">
        <p class="mb-6 text-sm text-text-secondary">{toolDesc}</p>
        <slot />
      </main>

      <footer class="border-t border-border px-4 py-4 text-sm text-text-muted lg:px-8">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <div class="flex items-center gap-2">
            <span>{t(lang, 'home_footerName')}</span>
            <span>&middot;</span>
            <span class="font-medium text-text-secondary">v{appVersion}</span>
          </div>
          <a href={upstreamRepositoryUrl} class="text-text-secondary transition-colors hover:text-accent">
            {t(lang, 'home_footerGithub')}
          </a>
        </div>
      </footer>
    </div>
  </div>

  <!-- Mobile menu + focus management -->
  <script>
    function initToolLayout() {
      // Mobile menu
      const toggle = document.getElementById('mobile-menu-toggle')
      const close = document.getElementById('mobile-menu-close')
      const overlay = document.getElementById('mobile-sidebar-overlay')
      const backdrop = document.getElementById('mobile-overlay-backdrop')

      if (toggle && overlay) {
        const openMenu = () => overlay.classList.remove('hidden')
        const closeMenu = () => overlay.classList.add('hidden')

        toggle.addEventListener('click', openMenu)
        close?.addEventListener('click', closeMenu)
        backdrop?.addEventListener('click', closeMenu)
        overlay.querySelectorAll('a').forEach((a) => {
          a.addEventListener('click', closeMenu)
        })
      }

      // Focus tool heading on navigation
      const heading = document.getElementById('tool-heading')
      if (heading) heading.focus()

      // Favorite toggle
      const favBtn = document.getElementById('favorite-toggle')
      if (favBtn) {
        const toolId = favBtn.dataset.toolId ?? ''
        const addLabel = favBtn.dataset.addLabel ?? ''
        const removeLabel = favBtn.dataset.removeLabel ?? ''
        const iconEmpty = document.getElementById('fav-icon-empty')
        const iconFilled = document.getElementById('fav-icon-filled')

        function getFavs(): string[] {
          try {
            const raw = localStorage.getItem('favorite-tools')
            if (!raw) return []
            const parsed = JSON.parse(raw)
            return Array.isArray(parsed) ? parsed.filter((v: unknown) => typeof v === 'string') : []
          } catch { return [] }
        }

        function updateFavIcon() {
          const isFav = getFavs().includes(toolId)
          if (iconEmpty && iconFilled) {
            iconEmpty.classList.toggle('hidden', isFav)
            iconFilled.classList.toggle('hidden', !isFav)
          }
          favBtn!.setAttribute('aria-label', isFav ? removeLabel : addLabel)
          favBtn!.setAttribute('title', isFav ? removeLabel : addLabel)
        }

        updateFavIcon()

        favBtn.addEventListener('click', () => {
          const current = getFavs()
          const idx = current.indexOf(toolId)
          if (idx === -1) {
            current.push(toolId)
          } else {
            current.splice(idx, 1)
          }
          try { localStorage.setItem('favorite-tools', JSON.stringify(current)) } catch {}
          updateFavIcon()
        })
      }

      const searchTrigger = document.getElementById('tool-search-trigger')
      if (searchTrigger && searchTrigger.dataset.bound !== 'true') {
        searchTrigger.dataset.bound = 'true'
        searchTrigger.addEventListener('click', () => {
          document.dispatchEvent(new KeyboardEvent('keydown', { key: 'k', metaKey: true }))
        })
      }

      // Theme toggle
      const themeBtn = document.getElementById('theme-toggle')
      if (themeBtn) {
        function getStoredPreference(): string {
          return localStorage.getItem('theme') || 'system'
        }

        function updateIcon(pref: string) {
          const iconLight = document.getElementById('theme-icon-light')
          const iconDark = document.getElementById('theme-icon-dark')
          const iconSystem = document.getElementById('theme-icon-system')
          if (!iconLight || !iconDark || !iconSystem) return
          iconLight.classList.add('hidden')
          iconDark.classList.add('hidden')
          iconSystem.classList.add('hidden')
          if (pref === 'light') iconDark.classList.remove('hidden')
          else if (pref === 'dark') iconLight.classList.remove('hidden')
          else iconSystem.classList.remove('hidden')
        }

        function applyTheme(pref: string) {
          let effective = pref
          if (pref === 'system') {
            effective = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light'
          }
          document.documentElement.setAttribute('data-theme', effective)
        }

        function cyclePref(current: string): string {
          if (current === 'system') return 'light'
          if (current === 'light') return 'dark'
          return 'system'
        }

        let pref = getStoredPreference()
        applyTheme(pref)
        updateIcon(pref)

        themeBtn.addEventListener('click', () => {
          pref = cyclePref(pref)
          if (pref === 'system') {
            localStorage.removeItem('theme')
          } else {
            localStorage.setItem('theme', pref)
          }
          applyTheme(pref)
          updateIcon(pref)
        })

        window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
          if (getStoredPreference() === 'system') {
            applyTheme('system')
          }
        })
      }
    }

    // Run on initial load and after every client-side navigation
    initToolLayout()
    document.addEventListener('astro:page-load', initToolLayout)
  </script>
</BaseLayout>
